# Environment (development/production)
ENVIRONMENT=development

PROJECT_NAME="Personal AI Copilot"
SECRET_KEY="generate-a-secure-random-key"

# Database URLs
# For local Docker: postgresql://copilot:copilotpassword@postgres:5432/copilot_db
# For production: postgresql://<user>:<pass>@<host>:<port>/<db>
DATABASE_URL="postgresql://copilot:copilotpassword@localhost:5432/copilot_db"

# Admin credentials
ADMIN_EMAIL="admin@copilot.local"
ADMIN_PASSWORD="admin123"

# Deepgram
DEEPGRAM_API_KEY=""

# LLM Providers
GROQ_API_KEY=""
GEMINI_API_KEY_1=""
GEMINI_API_KEY_2=""
